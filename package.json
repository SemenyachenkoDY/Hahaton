{
  "name": "hahaton-project",
  "version": "1.0.0",
  "scripts": {
    "start:backend": "cd backend && python -m uvicorn main:app --reload --port 8000",
    "start:frontend": "cd frontend && npm run dev",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
